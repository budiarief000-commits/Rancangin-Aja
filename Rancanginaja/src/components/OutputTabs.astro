<section class="output-section" id="outputSection">
    <!-- Tabs -->
    <div class="tabs" role="tablist">
        <button class="tab-btn active" id="tabBmc" role="tab" aria-selected="true">
            <span class="tab-icon">📊</span>
            <span class="tab-label">BMC</span>
        </button>
        <button class="tab-btn" id="tabImc" role="tab" aria-selected="false">
            <span class="tab-icon">📣</span>
            <span class="tab-label">IMC</span>
        </button>
        <button class="tab-btn" id="tabPrompts" role="tab" aria-selected="false">
            <span class="tab-icon">🎨</span>
            <span class="tab-label">Visual</span>
        </button>
        <button class="tab-btn" id="tabCopy" role="tab" aria-selected="false">
            <span class="tab-icon">✍️</span>
            <span class="tab-label">Copy</span>
        </button>
        <button class="tab-btn" id="tabBrand" role="tab" aria-selected="false">
            <span class="tab-icon">🎯</span>
            <span class="tab-label">Brand</span>
        </button>
        <button class="tab-btn" id="tabGrowth" role="tab" aria-selected="false">
            <span class="tab-icon">💡</span>
            <span class="tab-label">Growth</span>
        </button>
    </div>

    <!-- Tab Panels -->
    <div class="tab-content-wrapper glass-card" style="border-radius: 0 0 var(--radius-lg) var(--radius-lg); border-top: none;">
        <div class="tab-panel active" id="panelBmc" role="tabpanel">
            <div class="empty-state">
                <div class="empty-state__icon">📊</div>
                <p class="empty-state__title">Business Model Canvas</p>
                <p class="empty-state__text">Hasil BMC akan muncul di sini</p>
            </div>
        </div>
        <div class="tab-panel" id="panelImc" role="tabpanel">
            <div class="empty-state">
                <div class="empty-state__icon">📣</div>
                <p class="empty-state__title">Strategi IMC</p>
                <p class="empty-state__text">Hasil IMC akan muncul di sini</p>
            </div>
        </div>
        <div class="tab-panel" id="panelPrompts" role="tabpanel">
            <div class="empty-state">
                <div class="empty-state__icon">🎨</div>
                <p class="empty-state__title">Visual Prompts AI</p>
                <p class="empty-state__text">Prompt gambar AI akan muncul di sini</p>
            </div>
        </div>
        <div class="tab-panel" id="panelCopy" role="tabpanel">
            <div class="empty-state">
                <div class="empty-state__icon">✍️</div>
                <p class="empty-state__title">Tagline & Copywriting</p>
                <p class="empty-state__text">Hasil copywriting akan muncul di sini</p>
            </div>
        </div>
        <div class="tab-panel" id="panelBrand" role="tabpanel">
            <div class="empty-state">
                <div class="empty-state__icon">🎯</div>
                <p class="empty-state__title">Positioning & Branding</p>
                <p class="empty-state__text">Hasil positioning akan muncul di sini</p>
            </div>
        </div>
        <div class="tab-panel" id="panelGrowth" role="tabpanel">
            <div class="empty-state">
                <div class="empty-state__icon">💡</div>
                <p class="empty-state__title">Growth Hack Tips</p>
                <p class="empty-state__text">Tips pertumbuhan akan muncul di sini</p>
            </div>
        </div>
    </div>
</section>

<style>
    /* ========== OUTPUT SECTION ========== */
    .output-section {
        margin-top: 24px;
        animation: fadeSlideUp 0.8s ease-out 0.4s both;
        display: none;
    }

    .output-section.visible {
        display: block;
    }

    /* ========== TABS ========== */
    .tabs {
        display: flex;
        gap: 4px;
        padding: 6px;
        background: rgba(0, 0, 0, 0.3);
        border-radius: var(--radius-md);
        margin-bottom: 0;
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .tabs::-webkit-scrollbar {
        display: none;
    }

    .tab-btn {
        flex: 1;
        min-width: 0;
        padding: 12px 16px;
        background: transparent;
        border: none;
        border-radius: var(--radius-sm);
        color: var(--text-muted);
        font-family: 'Inter', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition-base);
        white-space: nowrap;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .tab-btn:hover {
        color: var(--text-secondary);
        background: rgba(255, 255, 255, 0.04);
    }

    .tab-btn.active {
        background: var(--glass-bg);
        color: var(--text-primary);
        border: 1px solid var(--glass-border);
        box-shadow: 0 2px 12px rgba(168, 85, 247, 0.15);
    }

    .tab-btn .tab-icon {
        font-size: 1.1rem;
    }

    /* ========== TAB CONTENT ========== */
    .tab-content-wrapper {
        background: var(--glass-bg);
        backdrop-filter: blur(20px) saturate(1.2);
        -webkit-backdrop-filter: blur(20px) saturate(1.2);
        border: 1px solid var(--glass-border);
        border-top: none;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
        padding: 32px;
        min-height: 300px;
    }

    .tab-panel {
        display: none;
        animation: tabFadeIn 0.4s ease-out;
    }

    .tab-panel.active {
        display: block;
    }

    @keyframes tabFadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ========== EMPTY STATE ========== */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: var(--text-muted);
    }

    .empty-state__icon {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.5;
    }

    .empty-state__title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 6px;
    }

    .empty-state__text {
        font-size: 0.85rem;
    }

    /* ========== MARKDOWN OUTPUT STYLES (Global logic or scoped) ========== */
    :global(.markdown-output) {
        font-size: 0.95rem;
        line-height: 1.8;
        color: var(--text-primary);
    }

    :global(.markdown-output h1) {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        margin: 24px 0 12px 0;
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    :global(.markdown-output h2) {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--accent-purple);
        margin: 24px 0 12px 0;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(168, 85, 247, 0.2);
    }

    :global(.markdown-output table) {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin: 28px 0;
        background: rgba(10, 5, 20, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    :global(.markdown-output th) {
        background: linear-gradient(90deg, rgba(168, 85, 247, 0.2), rgba(236, 72, 153, 0.15));
        color: #fff;
        padding: 16px 20px;
        text-align: left;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        border-bottom: 2px solid rgba(168, 85, 247, 0.3);
    }

    :global(.markdown-output td) {
        padding: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        vertical-align: top;
        font-size: 0.9rem;
        line-height: 1.7;
        color: var(--text-secondary);
    }

    /* Prompt Cards Styling */
    :global(.prompt-card) {
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--radius-md);
        padding: 20px;
        margin: 12px 0;
        position: relative;
        transition: var(--transition-base);
    }

    :global(.copy-btn) {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(168, 85, 247, 0.2);
        border: 1px solid rgba(168, 85, 247, 0.3);
        color: var(--accent-purple);
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition-base);
    }

    @media (max-width: 768px) {
        .tabs {
            gap: 2px;
            padding: 4px;
        }

        .tab-btn {
            padding: 10px 12px;
            font-size: 0.72rem;
        }

        .tab-content-wrapper {
            padding: 20px 16px;
        }
    }

    @media (max-width: 480px) {
        .tab-btn .tab-label {
            display: none;
        }

        .tab-btn .tab-icon {
            font-size: 1.3rem;
        }

        .tab-btn {
            padding: 12px;
        }
    }
</style>
